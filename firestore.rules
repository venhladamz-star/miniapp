rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProfile(data) {
      return data.keys().hasAll(['name', 'bank', 'account', 'updatedAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.bank is string && data.bank.size() <= 100 &&
             data.account is string && data.account.size() <= 50 &&
             data.updatedAt == request.time;
    }

    function isValidDebt(data) {
      return data.keys().hasAll(['person', 'amount', 'type', 'note', 'date', 'userId', 'createdAt']) &&
             data.keys().size() <= 8 && // Allowing optional fields if any
             data.person is string && data.person.size() <= 100 &&
             data.amount is number &&
             data.type in ['cho_vay', 'di_vay'] &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidQR(data) {
      return data.keys().hasAll(['name', 'image', 'number', 'holder', 'userId', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.name is string && data.name.size() <= 100 &&
             data.image is string && data.image.size() <= 1048576 && // 1MB limit for base64 strings in firestore
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Match Blocks ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /profile/main {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidProfile(incoming());
      }

      match /debts/{debtId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(debtId) && isValidDebt(incoming());
        allow update: if isOwner(userId) && isValidDebt(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['person', 'amount', 'type', 'note', 'date']);
        allow delete: if isOwner(userId);
      }

      match /qrs/{qrId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(qrId) && isValidQR(incoming());
        allow update: if isOwner(userId) && isValidQR(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'image', 'number', 'holder']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
